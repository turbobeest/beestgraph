# beestgraph/docker/.env.example
# Copy to .env and fill in your values:  cp .env.example .env

# ── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Vault path ───────────────────────────────────────────────
VAULT_PATH=$HOME/vault

# ── Graphiti model (used for entity extraction) ──────────────
# Use a cost-effective model for high-volume extraction
GRAPHITI_MODEL=claude-sonnet-4-20250514
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# ── keep.md (optional — MCP auth is via browser OAuth) ───────
# Only needed if using REST API directly instead of MCP
# KEEPMD_API_KEY=

# ── Telegram bot (optional) ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789

# ── FalkorDB ─────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ── Graphiti (requires OpenAI for embeddings) ──────────────
# OPENAI_API_KEY=sk-...
