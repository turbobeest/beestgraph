# beestgraph/docker/.env.example
# Copy to .env and customize: cp .env.example .env

# ── Vault path ───────────────────────────────────────────────
VAULT_PATH=$HOME/vault

# ── FalkorDB ─────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# ── keep.md (optional — for inbox poller) ────────────────────
# KEEPMD_API_KEY=

# ── Telegram bot (optional) ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789
