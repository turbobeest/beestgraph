# beestgraph .gitignore

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── Node.js ──────────────────────────────────────────────────
node_modules/
src/web/.next/
src/web/out/

# ── Testing / Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Environment / Secrets ────────────────────────────────────
.env
docker/.env
*.key
*.pem

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code ──────────────────────────────────────────────
.claude/logs/
.claude/tasks/

# ── Docker volumes (local dev) ───────────────────────────────
docker/data/

# ── Backups (generated by scripts/backup.sh) ─────────────────
backups/

# ── Config (user-specific, templates are tracked) ────────────
config/beestgraph.yml
config/mcp.json
