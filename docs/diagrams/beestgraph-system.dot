digraph beestgraph {
    // ── Global ──────────────────────────────────────────────
    graph [
        rankdir=TB
        bgcolor="white"
        fontname="Helvetica Neue"
        fontsize=11
        pad=0.4
        nodesep=0.55
        ranksep=0.7
        splines=true
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
            <TR><TD><FONT FACE="Helvetica Neue" POINT-SIZE="22" COLOR="#1a1a2e"><B>beestgraph</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Helvetica Neue" POINT-SIZE="12" COLOR="#666680">AI-augmented personal knowledge graph · system architecture</FONT></TD></TR>
        </TABLE>>
        labelloc=t
        labeljust=c
    ]
    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=1.2
    ]
    edge [
        fontname="Helvetica Neue"
        fontsize=8
        color="#8888aa"
        penwidth=1.1
        arrowsize=0.7
    ]

    // ── Color palette ───────────────────────────────────────
    // Capture:    #e8f0fe / #1a73e8  (blue)
    // Processing: #fef7e0 / #e8a317  (amber)
    // Storage:    #e6f4ea / #1e8e3e  (green)
    // Access:     #fce8e6 / #d93025  (red)
    // External:   #f3e8fd / #8430ce  (purple)

    // ════════════════════════════════════════════════════════
    //  CAPTURE LAYER
    // ════════════════════════════════════════════════════════
    subgraph cluster_capture {
        label=<<FONT FACE="Helvetica Neue" POINT-SIZE="13" COLOR="#1a73e8"><B>CAPTURE LAYER</B></FONT>>
        style="dashed,rounded"
        color="#1a73e8"
        bgcolor="#f6f9ff"
        penwidth=1.5
        margin=16

        subgraph cluster_keepmd {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#1a73e8"><B>keep.md  ($10/mo Plus)</B></FONT>>
            style="filled,rounded"
            color="#1a73e8"
            bgcolor="#e8f0fe"
            penwidth=1.0
            margin=12

            keep_ext    [label="Browser Extension\nCmd+Shift+K" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_mobile [label="Mobile Share Sheet\niOS / Android" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_x      [label="X/Twitter\nBookmark Sync" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_rss    [label="RSS / Atom\nFeed Monitor" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_yt     [label="YouTube\nTranscripts" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_gh     [label="GitHub\nStarred Repos" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_email  [label="Email Inbox\nNewsletters" fillcolor="#cfe2ff" color="#1a73e8"]
            keep_cloud  [label=<<B>keep.md Cloud</B><BR/>MCP · REST API · CLI> fillcolor="#1a73e8" fontcolor="white" color="#0d47a1" penwidth=1.5]
        }

        subgraph cluster_obsidian_cap {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#1a73e8"><B>Obsidian Capture</B></FONT>>
            style="filled,rounded"
            color="#1a73e8"
            bgcolor="#e8f0fe"
            penwidth=1.0
            margin=12

            obs_clipper [label="Obsidian Web Clipper\nFull article + frontmatter" fillcolor="#cfe2ff" color="#1a73e8"]
            obs_manual  [label="Manual Notes\nObsidian Editor" fillcolor="#cfe2ff" color="#1a73e8"]
        }

        keep_ext    -> keep_cloud
        keep_mobile -> keep_cloud
        keep_x      -> keep_cloud
        keep_rss    -> keep_cloud
        keep_yt     -> keep_cloud
        keep_gh     -> keep_cloud
        keep_email  -> keep_cloud
    }

    // ════════════════════════════════════════════════════════
    //  PROCESSING LAYER  (Raspberry Pi 5)
    // ════════════════════════════════════════════════════════
    subgraph cluster_processing {
        label=<<FONT FACE="Helvetica Neue" POINT-SIZE="13" COLOR="#e8a317"><B>PROCESSING LAYER</B>  ·  Raspberry Pi 5 · 16 GB · NVMe</FONT>>
        style="dashed,rounded"
        color="#e8a317"
        bgcolor="#fffdf5"
        penwidth=1.5
        margin=16

        subgraph cluster_intake {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#e8a317"><B>Intake Streams</B></FONT>>
            style="filled,rounded"
            color="#e8a317"
            bgcolor="#fef7e0"
            penwidth=1.0
            margin=12

            cron_keep   [label="Cron Job\n*/15 * * * *\nPoll keep.md inbox" fillcolor="#fff3cd" color="#e8a317"]
            watchdog    [label="Python Watchdog\nReal-time inotify\n~/vault/inbox/" fillcolor="#fff3cd" color="#e8a317"]
        }

        subgraph cluster_agent {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#e8a317"><B>AI Agent</B></FONT>>
            style="filled,rounded"
            color="#e8a317"
            bgcolor="#fef7e0"
            penwidth=1.0
            margin=12

            claude_code [label=<<B>Claude Code</B><BR/>Headless Mode  ·  Opus 4.6<BR/><FONT POINT-SIZE="8">CLAUDE.md context · Custom skills</FONT>> fillcolor="#e8a317" fontcolor="white" color="#b8860b" penwidth=1.5]
        }

        subgraph cluster_mcp {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#e8a317"><B>MCP Constellation</B></FONT>>
            style="filled,rounded"
            color="#e8a317"
            bgcolor="#fef7e0"
            penwidth=1.0
            margin=12

            mcp_keep     [label="keep.md MCP\nlist_inbox · get_item\nmark_done · search" fillcolor="#e8f0fe" color="#1a73e8"]
            mcp_fs       [label="Filesystem MCP\nread · write · list\nsearch_files" fillcolor="#fff3cd" color="#e8a317"]
            mcp_falkor   [label="FalkorDB MCP\nNL → Cypher\nraw queries" fillcolor="#e6f4ea" color="#1e8e3e"]
        }
    }

    // ════════════════════════════════════════════════════════
    //  STORAGE LAYER
    // ════════════════════════════════════════════════════════
    subgraph cluster_storage {
        label=<<FONT FACE="Helvetica Neue" POINT-SIZE="13" COLOR="#1e8e3e"><B>STORAGE LAYER</B>  ·  2 TB NVMe</FONT>>
        style="dashed,rounded"
        color="#1e8e3e"
        bgcolor="#f4faf6"
        penwidth=1.5
        margin=16

        subgraph cluster_graph {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#1e8e3e"><B>Graph Database</B></FONT>>
            style="filled,rounded"
            color="#1e8e3e"
            bgcolor="#e6f4ea"
            penwidth=1.0
            margin=12

            falkordb [label=<<B>FalkorDB</B><BR/>In-memory graph · GraphBLAS<BR/><FONT POINT-SIZE="8">OpenCypher · Full-text · Vector index</FONT>> fillcolor="#1e8e3e" fontcolor="white" color="#0d652d" penwidth=1.5]
        }

        subgraph cluster_vault {
            label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#1e8e3e"><B>Obsidian Vault</B></FONT>>
            style="filled,rounded"
            color="#1e8e3e"
            bgcolor="#e6f4ea"
            penwidth=1.0
            margin=12

            vault_inbox [label="inbox/\nNew captures" fillcolor="#c8e6c9" color="#1e8e3e"]
            vault_know  [label="knowledge/\nProcessed articles" fillcolor="#c8e6c9" color="#1e8e3e"]
            vault_para  [label="projects/ · areas/\nresources/ · archives/" fillcolor="#c8e6c9" color="#1e8e3e"]
            syncthing   [label=<<B>Syncthing</B><BR/>P2P vault sync<BR/><FONT POINT-SIZE="8">All devices</FONT>> fillcolor="#1e8e3e" fontcolor="white" color="#0d652d" penwidth=1.5]
        }

    }

    // ════════════════════════════════════════════════════════
    //  ACCESS LAYER
    // ════════════════════════════════════════════════════════
    subgraph cluster_access {
        label=<<FONT FACE="Helvetica Neue" POINT-SIZE="13" COLOR="#d93025"><B>ACCESS LAYER</B>  ·  via Tailscale mesh VPN</FONT>>
        style="dashed,rounded"
        color="#d93025"
        bgcolor="#fef6f5"
        penwidth=1.5
        margin=16

        falkor_ui  [label=<<B>FalkorDB Browser</B><BR/>Graph viz · Cypher editor<BR/><FONT POINT-SIZE="8">:3000</FONT>> fillcolor="#fce8e6" color="#d93025"]
        web_ui     [label=<<B>beestgraph Web UI</B><BR/>Cytoscape.js · Search<BR/><FONT POINT-SIZE="8">Next.js  ·  :3001</FONT>> fillcolor="#d93025" fontcolor="white" color="#a50e0e" penwidth=1.5]
        telegram   [label="Telegram Bot\n/status /process\n/search /recent" fillcolor="#fce8e6" color="#d93025"]
        ssh_tmux   [label="SSH + tmux + mosh\nClaude Code interactive" fillcolor="#fce8e6" color="#d93025"]
        obsidian   [label="Obsidian Desktop\n& Mobile" fillcolor="#fce8e6" color="#d93025"]
    }

    // ════════════════════════════════════════════════════════
    //  NETWORK
    // ════════════════════════════════════════════════════════
    subgraph cluster_network {
        label=<<FONT FACE="Helvetica Neue" POINT-SIZE="10" COLOR="#8430ce"><B>NETWORK</B></FONT>>
        style="filled,rounded"
        color="#8430ce"
        bgcolor="#f3e8fd"
        penwidth=1.0
        margin=12

        tailscale [label=<<B>Tailscale</B><BR/>WireGuard mesh VPN<BR/><FONT POINT-SIZE="8">ACLs · MagicDNS · No port forwarding</FONT>> fillcolor="#8430ce" fontcolor="white" color="#5e1d99" penwidth=1.5]
        fios      [label="Verizon FiOS\n1 Gbps symmetric" fillcolor="#e8d5f5" color="#8430ce"]
    }

    // ════════════════════════════════════════════════════════
    //  EDGES — Capture → Processing
    // ════════════════════════════════════════════════════════
    keep_cloud  -> cron_keep    [label="  MCP poll  " color="#1a73e8"]
    obs_clipper -> vault_inbox  [label="  save to vault  " color="#1a73e8"]
    obs_manual  -> vault_inbox  [color="#1a73e8"]
    vault_inbox -> watchdog     [label="  inotify  " color="#e8a317"]

    // ── Intake → Agent ──
    cron_keep -> claude_code [color="#e8a317"]
    watchdog  -> claude_code [color="#e8a317"]

    // ── Agent ↔ MCP ──
    claude_code -> mcp_keep     [dir=both color="#1a73e8"]
    claude_code -> mcp_fs       [dir=both color="#e8a317"]
    claude_code -> mcp_falkor   [dir=both color="#1e8e3e"]

    // ── MCP → Storage ──
    mcp_keep     -> keep_cloud  [label="  API calls  " style=dashed color="#1a73e8"]
    mcp_fs       -> vault_inbox [color="#e8a317"]
    mcp_fs       -> vault_know  [color="#e8a317"]
    mcp_fs       -> vault_para  [color="#e8a317"]
    mcp_falkor   -> falkordb    [color="#1e8e3e"]

    // ── Vault sync ──
    vault_know -> syncthing [dir=both style=dashed color="#1e8e3e"]
    vault_para -> syncthing [dir=both style=dashed color="#1e8e3e"]

    // ── Access → Storage ──
    falkor_ui -> falkordb   [color="#d93025"]
    web_ui    -> falkordb   [color="#d93025"]
    telegram  -> claude_code [label="  commands  " color="#d93025"]
    ssh_tmux  -> claude_code [color="#d93025"]
    obsidian  -> syncthing  [dir=both label="  vault sync  " color="#d93025"]

    // ── Network ──
    tailscale -> falkor_ui [style=dotted color="#8430ce"]
    tailscale -> web_ui    [style=dotted color="#8430ce"]
    tailscale -> ssh_tmux  [style=dotted color="#8430ce"]
    fios      -> tailscale [color="#8430ce"]
}
